# Minimum local seeded/demo mode
# Leave the live-only secrets below empty to keep the app in seeded demo fallback.
# Set APP_REGION_BLOCKLIST=US for the default restricted posture, or leave it
# empty on the hackathon deployment so judge wallet sign-in is not blocked.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
APP_REGION_BLOCKLIST=

# Full live mode
NEXT_PUBLIC_HELIUS_RPC_URL=
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PRIVATE_BUCKET=
PINATA_JWT=
SESSION_SECRET=
SOLANA_ADMIN_MULTISIG=
SETTLEMENT_MINT_ADDRESS=So11111111111111111111111111111111111111112
# Legacy fallback used by older local/runtime code paths. Keep aligned with
# SETTLEMENT_MINT_ADDRESS if you still rely on it.
USDC_MINT_ADDRESS=
NEXT_PUBLIC_PROGRAM_ID_KLASTER_VAULT=
PROGRAM_ID_KLASTER_VAULT=

# Optional analytics and notifications
POSTHOG_KEY=
POSTHOG_HOST=
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
